# little-crab Environment Configuration
# Copy this file to .env and adjust paths if needed.

# little-crab is local-only.
STORAGE_MODE=local

# Embedded storage directory
LOCAL_DATA_DIR=./opencrab_data

# Embedded Chroma collection name
CHROMA_COLLECTION=little_crab_vectors

# MCP
MCP_SERVER_NAME=little-crab
MCP_SERVER_VERSION=0.1.0

# Logging
LOG_LEVEL=INFO
